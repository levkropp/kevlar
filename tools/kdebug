#!/usr/bin/env python3
"""kdebug — run a Kevlar test with GDB attached and auto-capture panic state.

Spawns QEMU with `--gdb` (waits paused on :7789), then attaches GDB in
batch mode. GDB sets a breakpoint at the panic handler. When the kernel
panics, GDB dumps full register state, the stack, and a backtrace —
to stderr in real time and to a `kdebug.out` file.

Usage:
  tools/kdebug test-xfce          # run `make test-xfce` under GDB
  tools/kdebug test-threads-smp   # any make target works

The test runs to completion if no panic happens. On panic, GDB stops
the kernel, prints the post-mortem, and detaches (so QEMU can dump
its own crash dump and exit).
"""

import argparse
import os
import subprocess
import sys
import time
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
GDB_BINARY = "rust-gdb"  # from rustup; falls back to gdb
GDB_PORT = 7789
KERNEL_ELF = REPO / "target" / "x64-unwind" / "debug" / "kevlar_kernel"

GDB_SCRIPT = """
file {kernel}
target remote :{port}
set pagination off
set print pretty on
set print elements 64
set disassembly-flavor intel
set confirm off

# Trap every panic with full state. The Rust panic entry symbol is
# mangled; we look it up at runtime by address. Use hbreak (hardware
# breakpoint) since the kernel image isn't mapped yet at GDB attach
# time and software breakpoints can't be written until the page
# tables are loaded.
hbreak *{panic_addr:#x}
commands
    printf "\\n=== KEVLAR PANIC ===\\n"
    info registers
    printf "stack at rsp:\\n"
    x/16gx $rsp
    printf "backtrace:\\n"
    backtrace 20
    printf "\\n--- frames via rbp (manual) ---\\n"
    # Dump 256 bytes starting at rbp; shows ~16 frames worth of links.
    x/64gx $rbp
    printf "\\n--- PtRegs at rdi=%#lx (passed to handle_kernel_page_fault) ---\\n", $rdi
    # PtRegs layout (platform/x64/cpu.rs): r15, r14, r13, r12, rbp, rbx,
    # r11, r10, r9, r8, rax, rcx, rdx, rsi, rdi, error_code, rip, cs,
    # rflags, rsp, ss = 21 u64s.
    x/21gx $rdi
    printf "===\\n"
    # Detach so QEMU can finish its own crash dump.
    detach
    quit
end

# Run the kernel.
continue
"""


def find_panic_addr(kernel_path: Path) -> int | None:
    """Resolve the address of `rust_begin_unwind` from the kernel ELF."""
    try:
        out = subprocess.check_output(
            ["nm", str(kernel_path)],
            text=True,
        )
    except Exception:
        return None
    for line in out.splitlines():
        # Mangled form: ..._7___rustc17rust_begin_unwind
        if "rust_begin_unwind" in line:
            parts = line.split()
            if len(parts) >= 1:
                try:
                    return int(parts[0], 16)
                except ValueError:
                    continue
    return None


def main():
    ap = argparse.ArgumentParser(description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("target", help="make target to run (e.g. test-xfce)")
    ap.add_argument("--profile", default="balanced",
                    help="kernel profile (default: balanced)")
    ap.add_argument("--out", default="kdebug.out",
                    help="GDB output file (default: kdebug.out)")
    ap.add_argument("--gdb-binary", default=GDB_BINARY)
    ap.add_argument("--port", type=int, default=GDB_PORT)
    args = ap.parse_args()

    if not KERNEL_ELF.exists():
        print(f"kernel ELF not found at {KERNEL_ELF}; run `make build` first.",
              file=sys.stderr)
        return 2

    env = os.environ.copy()
    env["KEVLAR_GDB"] = "1"

    print(f"[kdebug] launching: make {args.target} PROFILE={args.profile}",
          file=sys.stderr)
    print(f"[kdebug] kernel ELF: {KERNEL_ELF}", file=sys.stderr)
    print(f"[kdebug] gdb output: {args.out}", file=sys.stderr)

    qemu = subprocess.Popen(
        ["make", args.target, f"PROFILE={args.profile}"],
        cwd=REPO,
        env=env,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
    )

    # QEMU starts paused; wait until the GDB port is listening.
    deadline = time.time() + 60
    while time.time() < deadline:
        try:
            with subprocess.Popen(
                ["bash", "-c", f"exec 3<>/dev/tcp/127.0.0.1/{args.port}"],
                stderr=subprocess.DEVNULL,
            ) as p:
                p.wait(timeout=2)
                if p.returncode == 0:
                    break
        except Exception:
            pass
        time.sleep(0.5)
    else:
        print("[kdebug] timed out waiting for GDB port; aborting", file=sys.stderr)
        qemu.kill()
        return 1

    print(f"[kdebug] GDB port ready on :{args.port}; attaching", file=sys.stderr)

    # Resolve the panic-handler address from the ELF.
    panic_addr = find_panic_addr(KERNEL_ELF)
    if panic_addr is None:
        print("[kdebug] could not find rust_begin_unwind in kernel ELF",
              file=sys.stderr)
        qemu.kill()
        return 1
    print(f"[kdebug] panic breakpoint at {panic_addr:#x}", file=sys.stderr)

    # Write the gdb command script to a temp file.
    script_path = Path("/tmp/kdebug.gdb")
    script_path.write_text(GDB_SCRIPT.format(
        kernel=str(KERNEL_ELF),
        port=args.port,
        panic_addr=panic_addr,
    ))

    out_file = open(args.out, "w")
    gdb = subprocess.Popen(
        [args.gdb_binary, "-batch", "-x", str(script_path)],
        cwd=REPO,
        stdout=out_file,
        stderr=subprocess.STDOUT,
    )

    # Stream QEMU (kernel serial) output to our stderr AND tee into a
    # companion file so we can correlate it with the GDB-captured
    # panic state.
    serial_path = Path(args.out).with_suffix(".serial")
    serial_file = open(serial_path, "wb")
    while True:
        line = qemu.stdout.readline()
        if not line:
            break
        sys.stderr.buffer.write(line)
        sys.stderr.buffer.flush()
        serial_file.write(line)
    serial_file.close()
    print(f"[kdebug] kernel serial in: {serial_path}", file=sys.stderr)

    qemu.wait()
    gdb.wait()
    out_file.close()

    print(f"\n[kdebug] done. GDB output in: {args.out}", file=sys.stderr)
    if Path(args.out).stat().st_size > 0:
        print(f"[kdebug] last 40 lines of GDB output:", file=sys.stderr)
        with open(args.out) as f:
            tail = f.readlines()[-40:]
            sys.stderr.write("".join(tail))

    return 0 if qemu.returncode in (0, None) else 1


if __name__ == "__main__":
    sys.exit(main())
