# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly declare text files
*.c text eol=lf
*.h text eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.S text eol=lf
*.asm text eol=lf
*.ld text eol=lf
*.cfg text eol=lf
*.config text eol=lf
*.patch text eol=lf
Dockerfile* text eol=lf
Makefile* text eol=lf
*.mk text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.xz binary
*.bin binary
*.elf binary
*.o binary
*.a binary
*.so binary
*.dylib binary
*.dll binary
*.exe binary
